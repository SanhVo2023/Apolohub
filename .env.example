# =============================================================================
# Apolo Content Hub — Environment Variables
# =============================================================================
# App:        hub (centralized CMS for the 21-site Apolo Legal Ecosystem)
# Project:    Apolo Funnel Sites (Supabase project zxmdegfnjbvytjnwfhfq, Singapore)
# Schema:     hub  (set in src/payload.config.ts via postgresAdapter({ schemaName: 'hub' }))
# Password:   see PM_CREDENTIALS.md at workspace root
# Dev port:   3001  (avoids colliding with sites on 3000/3300)
# =============================================================================

# ---- Database ---------------------------------------------------------------
# Session Pooler URI (port 5432, host aws-1-ap-southeast-1.pooler.supabase.com).
# IPv4 compatible, supports prepared statements — single URI handles runtime AND `npx payload migrate`.
# The %23 in the password is an encoded '#'. Keep it encoded.
DATABASE_URI=postgresql://postgres.zxmdegfnjbvytjnwfhfq:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# ---- Payload ----------------------------------------------------------------
# Random 32+ character string. Boot hard-fails if missing or the literal placeholder.
PAYLOAD_SECRET=replace-with-32-plus-random-chars

# ---- Public site URL --------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ---- Supabase project ref (Funnel) ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://zxmdegfnjbvytjnwfhfq.supabase.co

# ---- Seed script (scripts/seed.mjs) -----------------------------------------
SEED_ADMIN_EMAIL=matvietdesignteam@gmail.com
SEED_ADMIN_PASSWORD=replace-with-strong-password
